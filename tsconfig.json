{
  "compilerOptions": {
    "target": "es2023",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["es2023"],
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node", "express"],
    "outDir": "./dist",
    "rootDir": "./src",
    "sourceMap": true,
  },
  "include": ["src"]
}
